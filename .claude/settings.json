{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-verify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-command-guard.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Bash(go test:*)",
      "Bash(golangci-lint run:*)",
      "Bash(staticcheck:*)",
      "Bash(tc:*)",
      "Bash(tcpdump:*)",
      "Bash(tshark:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo rm -rf /:*)"
    ]
  }
}
